{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ipw-cn",
	"compatibility_date": "2026-07-08",
	"observability": {
		"enabled": true
	},
	"main": "./.output/server/index.mjs",
	"assets": {
		"binding": "ASSETS",
		"directory": "./.output/public/"
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
}